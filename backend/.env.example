# Example environment variables for the backend
# Copy this to .env and fill in values before running

# Postgres connection can be either a full DATABASE_URL or individual PG_* vars
DATABASE_URL=postgres://user:password@localhost:5432/mydb
PGHOST=localhost
PGUSER=user
PGPASSWORD=password
PGDATABASE=mydb
PGPORT=5432

# Server
PORT=5000
NODE_ENV=development
