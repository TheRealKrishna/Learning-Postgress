// Prisma schema for migrating from raw Postgres to Prisma.
// Connection URLs are configured in `prisma.config.ts` (Prisma 7).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}
